@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-4 fw-bold mb-3">
            <i class="bi bi-file-earmark-text text-primary"></i> PayslipsManager
        </h1>
        <p class="lead text-muted">Secure access to your monthly payslips</p>
        
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-4">
                <p class="mb-3 fs-5">Welcome back, <strong>@User.Identity.Name</strong>!</p>
                <a asp-controller="Payslips" asp-action="Index" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-folder2-open"></i> View My Payslips
                </a>
            </div>
        }
        else
        {
            <div class="mt-4">
                <p class="mb-3 fs-5">Sign in with your corporate account to access your payslips.</p>
                <a asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </a>
            </div>
        }
    </div>

    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center py-4">
                    <i class="bi bi-shield-check" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3 fw-semibold">Secure Access</h5>
                    <p class="card-text text-muted">Your payslips are protected with Microsoft Entra ID authentication.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center py-4">
                    <i class="bi bi-cloud-arrow-down" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3 fw-semibold">Azure Blob Storage</h5>
                    <p class="card-text text-muted">Documents stored securely in Azure with optimized access tiers.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center py-4">
                    <i class="bi bi-file-earmark-pdf" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3 fw-semibold">Easy Download</h5>
                    <p class="card-text text-muted">View and download your payslips anytime, anywhere.</p>
                </div>
            </div>
        </div>
    </div>
</div>
