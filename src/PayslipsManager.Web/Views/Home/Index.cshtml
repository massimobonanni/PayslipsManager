@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="text-center">
        <h1 class="display-4 mb-4">
            <i class="bi bi-file-earmark-text"></i> PayslipsManager
        </h1>
        <p class="lead">Secure access to your monthly payslips</p>
        
        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="mt-4">
                <p class="mb-3">Welcome back, <strong>@User.Identity.Name</strong>!</p>
                <a asp-controller="Payslips" asp-action="Index" class="btn btn-primary btn-lg">
                    <i class="bi bi-folder2-open"></i> View My Payslips
                </a>
            </div>
        }
        else
        {
            <div class="mt-4">
                <p class="mb-3">Please sign in with your corporate account to access your payslips.</p>
                <a asp-controller="MicrosoftIdentity" asp-action="SignIn" asp-area="MicrosoftIdentity" class="btn btn-primary btn-lg">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </a>
            </div>
        }
    </div>

    <div class="row mt-5">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="bi bi-shield-check" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3">Secure Access</h5>
                    <p class="card-text">Your payslips are protected with Microsoft Entra ID authentication.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="bi bi-cloud-arrow-down" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3">Azure Blob Storage</h5>
                    <p class="card-text">Documents stored securely in Azure with optimized access tiers.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-pdf" style="font-size: 3rem; color: #0d6efd;"></i>
                    <h5 class="card-title mt-3">Easy Download</h5>
                    <p class="card-text">View and download your payslips anytime, anywhere.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
