@model IReadOnlyList<PayslipsManager.Application.DTOs.PayslipListItemDto>
@{
    ViewData["Title"] = "My Payslips";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">
                <i class="bi bi-file-earmark-text"></i> My Payslips
            </h1>
            
            <div class="alert alert-info">
                <strong>Welcome, @ViewData["UserName"]!</strong><br />
                Signed in as: <strong>@ViewData["UserEmail"]</strong>
            </div>

            @if (Model != null && Model.Count > 0)
            {
                <div class="card">
                    <div class="card-body">
                        <p class="text-muted">You have <strong>@Model.Count</strong> payslip(s) available.</p>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Period</th>
                                        <th>File Name</th>
                                        <th>Uploaded</th>
                                        <th>Access Tier</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var payslip in Model)
                                    {
                                        <tr>
                                            <td><strong>@payslip.Period</strong></td>
                                            <td>@payslip.FileName</td>
                                            <td>@payslip.UploadedOn.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td>
                                                <span class="badge bg-@(payslip.AccessTier == "Hot" ? "danger" : payslip.AccessTier == "Cool" ? "info" : "secondary")">
                                                    @payslip.AccessTier
                                                </span>
                                                @if (payslip.IsArchived)
                                                {
                                                    <span class="badge bg-warning text-dark">Archived</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@payslip.BlobName" class="btn btn-sm btn-info" title="View Details">
                                                        <i class="bi bi-info-circle"></i> Details
                                                    </a>
                                                    <a asp-action="Download" asp-route-id="@payslip.BlobName" class="btn btn-sm btn-primary" title="Download PDF">
                                                        <i class="bi bi-download"></i> Download
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    <h4 class="alert-heading">No Payslips Found</h4>
                    <p>You don't have any payslips available at the moment. Please contact HR if you believe this is an error.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
