@model PayslipsManager.Application.DTOs.PayslipDetailsDto
@{
    ViewData["Title"] = $"Payslip Details - {Model.Period}";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">My Payslips</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Period</li>
                </ol>
            </nav>

            <h1 class="mb-4">
                <i class="bi bi-file-earmark-text"></i> Payslip Details
            </h1>

            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Period: @Model.Period</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h5>Document Information</h5>
                            <dl class="row">
                                <dt class="col-sm-4">File Name:</dt>
                                <dd class="col-sm-8">@Model.FileName</dd>

                                <dt class="col-sm-4">Content Type:</dt>
                                <dd class="col-sm-8">@Model.ContentType</dd>

                                <dt class="col-sm-4">Uploaded:</dt>
                                <dd class="col-sm-8">@Model.UploadedOn.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                                <dt class="col-sm-4">Access Tier:</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-@(Model.AccessTier == "Hot" ? "danger" : Model.AccessTier == "Cool" ? "info" : "secondary")">
                                        @Model.AccessTier
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <hr />

                    <div class="d-grid gap-2 d-md-flex justify-content-md-start">
                        <a asp-action="Download" asp-route-id="@Model.BlobName" class="btn btn-primary btn-lg">
                            <i class="bi bi-download"></i> Download PDF
                        </a>
                        <a asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </div>
                </div>
            </div>

            @if (Model.ArchiveWarning != null)
            {
                <div class="alert alert-warning mt-3">
                    <h5 class="alert-heading">Archived Document</h5>
                    <p>@Model.ArchiveWarning.Message</p>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
