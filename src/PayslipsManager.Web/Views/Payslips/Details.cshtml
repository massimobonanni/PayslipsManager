@model PayslipsManager.Application.DTOs.PayslipDetailsDto
@{
    ViewData["Title"] = $"Payslip Details - {Model.Period}";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">My Payslips</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@Model.Period</li>
                </ol>
            </nav>

            <h1 class="mb-4">
                <i class="bi bi-file-earmark-text"></i> Payslip Details
            </h1>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger d-flex align-items-center">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@TempData["Error"]</div>
                </div>
            }

            @if (Model.ArchiveWarning != null)
            {
                <div class="alert alert-warning d-flex align-items-start">
                    <i class="bi bi-archive me-2" style="font-size: 1.4rem;"></i>
                    <div>
                        <strong>Restore Required</strong><br />
                        <span>@Model.ArchiveWarning.Message</span>
                    </div>
                </div>
            }

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="bi bi-calendar3"></i> @Model.Period</h4>
                    <span class="badge bg-@(Model.AccessTier == "Hot" ? "success" : Model.AccessTier == "Cool" ? "info" : "secondary") fs-6">
                        @Model.AccessTier
                    </span>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">File Name</dt>
                        <dd class="col-sm-8">@Model.FileName</dd>

                        <dt class="col-sm-4">Content Type</dt>
                        <dd class="col-sm-8">@Model.ContentType</dd>

                        <dt class="col-sm-4">Uploaded</dt>
                        <dd class="col-sm-8">@Model.UploadedOn.ToString("yyyy-MM-dd HH:mm:ss")</dd>

                        <dt class="col-sm-4">Access Tier</dt>
                        <dd class="col-sm-8">
                            <span class="badge bg-@(Model.AccessTier == "Hot" ? "success" : Model.AccessTier == "Cool" ? "info" : "secondary")">
                                @Model.AccessTier
                            </span>
                            @if (Model.IsArchived)
                            {
                                <span class="badge bg-warning text-dark ms-1">
                                    <i class="bi bi-archive"></i> Restore required
                                </span>
                            }
                        </dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (Model.IsArchived)
                            {
                                <span class="text-warning fw-semibold"><i class="bi bi-archive"></i> Archived</span>
                            }
                            else
                            {
                                <span class="text-success fw-semibold"><i class="bi bi-check-circle"></i> Available</span>
                            }
                        </dd>
                    </dl>
                </div>
                <div class="card-footer bg-white d-flex gap-2">
                    @if (Model.IsArchived)
                    {
                        <button class="btn btn-secondary btn-lg" disabled
                                title="This payslip is archived and must be restored before download">
                            <i class="bi bi-archive"></i> Download Unavailable
                        </button>
                    }
                    else
                    {
                        <a asp-action="Download" asp-route-id="@Model.BlobName" class="btn btn-primary btn-lg">
                            <i class="bi bi-download"></i> Download PDF
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
